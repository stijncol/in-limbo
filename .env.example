# Database
DATABASE_URL=postgresql://user:pass@localhost/dbname

# Authentication
ADMIN_USER=admin
ADMIN_PASS=your-secure-password-here
STUDENT_USER=student
STUDENT_PASS=your-student-password-here

# External APIs (optional)
VIMEO_ACCESS_TOKEN=
YOUTUBE_API_KEY=

# Canonical site URL (optional) — when set, other hostnames 301-redirect here
# and absolute OG/canonical tags are emitted, e.g. https://www.example.com
SITE_URL=

# Server
PORT=3000
NODE_ENV=development